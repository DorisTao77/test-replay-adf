						"userProperties": [],
						"typeProperties": {
							"method": "GET",
							"headers": {},
							"url": "https://api.powerbi.cn/v1.0/myorg/groups/714c16d8-ede5-44a7-af1d-e35f67fc380d/datasets",
							"connectVia": {
								"referenceName": "AutoResolveIntegrationRuntime",

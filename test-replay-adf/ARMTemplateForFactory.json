				"type": "ServicePrincipal",
				"typeProperties": {
					"tenant": "954ddad8-66d7-47a8-8f9f-1316152d9587",
					"servicePrincipalId": "7b744948-3107-45f4-ad63-a55ad60b74be",
					"servicePrincipalKey": {
						"type": "AzureKeyVaultSecret",
						"store": {
							"referenceName": "AzureKeyVault1",
							"type": "LinkedServiceReference"

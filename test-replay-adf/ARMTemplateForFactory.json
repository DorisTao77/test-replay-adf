			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureDatabricks",
				"typeProperties": {
					"domain": "https://adb-257306723344475.3.databricks.azure.cn",
					"accessToken": {
						"type": "SecureString",
